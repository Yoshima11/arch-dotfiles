{
    "layer": "top",
    "position": "top",
    "height": 32,
    "css": "~/.config/waybar/style.css",

    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["custom/my_cpu", "custom/my_ram", "custom/my_gpu", "custom/my_disk", "pulseaudio", "clock", "tray"],

    "sway/workspaces": {
    	"all-outputs": false,
    	"disable-scroll": true,
    	"format": "{icon}",
    	"format-icons": {
        	"1": "一",
        	"2": "二",
        	"3": "三",
        	"4": "四",
        	"5": "五",
        	"6": "六",
        	"7": "七",
        	"8": "八",
        	"9": "九",
        	"10": "十",
        	"urgent": "⚠",
        	"default": "○"
    	}
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "🔇 Muted",
        "format-icons": ["🔈", "🔉", "🔊"],
        "on-click": "GTK_THEME=Adwaita-dark pavucontrol"
    },

    "clock": {
        "format": "🕒 {:%H:%M:%S}",
        "format-alt": "📅 {:%a, %d %b %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "interval": 1,
	"locale": "es_ES.UTF-8",
        "timezone": "America/Argentina/Buenos_Aires",
	"interval": 1,
        "on-click-right": "GTK_THEME=Adwaita-dark LC_TIME=es_ES.UTF-8 ~/.config/waybar/scripts/yad-calendar.sh"
    },

    "cpu": {
        "format": "<span color='#d8d8d8'> </span> {usage}%",
        "tooltip": "CPU: {usage}%",
        "interval": 5
    },

    "memory": {
        "format": "<span color='#d8d8d8'> </span> {used:0.1f}G",
        "format-alt": "<span color='#d8d8d8'> </span> {percentage}%",
        "tooltip": "RAM: {used:0.1f}G/{total:0.1f}G",
        "interval": 5
    },

    "custom/my_cpu": {
        "format": "<span color='#d8d8d8'></span>{}",
        "exec": "~/.config/waybar/scripts/my_cpu.sh",
        "return-type": "json",
        "interval": 5,
        "tooltip": true
    },

    "custom/my_ram": {
        "format": "<span color='#d8d8d8'>󰍛 </span>{}",
        "exec": "~/.config/waybar/scripts/my_ram.sh",
        "return-type": "json",
        "interval": 5,
        "tooltip": true
    },

    "custom/my_gpu": {
        "format": "<span color='#d8d8d8'> 󰢮 </span>{}",
        "exec": "~/.config/waybar/scripts/my_gpu.sh",
        "return-type": "json",
        "interval": 5,
        "tooltip": true
    },

    "custom/my_disk": {
        "format": "<span color='#d8d8d8'>󰋊 </span>{}",
        "exec": "~/.config/waybar/scripts/my_disk.sh",
        "return-type": "json",
        "interval": 60,
        "tooltip": true
    },

    "sys-info": {
        "format": "<span color='#00f2ff'> </span> {usage}%",
        "exec": "top -bn1 | grep 'Cpu(s)' | awk '{print $2 + $4}'",
        "tooltip": "~/.config/waybar/scripts/my_gpu_tooltip.sh",
        "interval": 5,
    },

    "temperature": {
    	"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    	"format": "🌡️ {temperatureC}°C",
    	"format-critical": "🔥 {temperatureC}°C",
    	"critical-threshold": 80,
    	"interval": 5,
    	"tooltip": true,
    	"tooltip-format": "CPU Temp: {temperatureC}°C"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip": "Batería: {capacity}%",
        "states": {
            "warning": 30,
            "critical": 15
        }
    }
}
